{
  "name": "echosight",
  "version": "1.2.0",
  "description": "Simple task management overlay for Path of Exile 2",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "node tests/run-tests.js",
    "test:unit": "node tests/run-tests.js unit",
    "test:integration": "node tests/run-tests.js integration",
    "test:e2e": "node tests/run-tests.js e2e",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "build-win": "npm run build && electron-builder --win --publish=never",
    "build-mac": "npm run build && electron-builder --mac --publish=never",
    "build-linux": "npm run build && electron-builder --linux --publish=never",
    "dist": "npm run build && electron-builder --publish=never",
    "pack": "npm run build && electron-builder --dir",
    "release": "node scripts/release.js"
  },
  "build": {
    "appId": "com.poe2tools.task-overlay",
    "productName": "Echosight PoE Task Overlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.2"
  },
  "keywords": [
    "path-of-exile",
    "poe2",
    "overlay",
    "task-management",
    "gaming"
  ],
  "author": "Echologist <echo@dont-fuck.me>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/echologist/echoesight-overlay.git"
  }
}
